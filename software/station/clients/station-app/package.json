{
  "name": "@normacore/station-app",
  "version": "0.1.0-beta.1",
  "description": "Desktop Electron wrapper for NormaCore station-viewer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/norma-core/norma-core.git",
    "directory": "software/station/clients/station-app"
  },
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "start": "electron .",
    "package": "electron-builder --config electron-builder.yml",
    "package:mac": "electron-builder --mac --config electron-builder.yml",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
